PROJECT_NAME=Quick FastAPI Medium                 # 项目名称
VERSION=0.1.0                                    # 版本号
API_V1_STR=/api/v1                               # API 基础路径
DEBUG=true                                       # 是否开启调试模式
ENVIRONMENT=development                          # 环境名（development/production等）

DATABASE_URL=postgresql+psycopg://postgres:123456@localhost:5432/quick_fastapi_medium  # 数据库连接URL
DATABASE_ECHO=false                              # SQLAlchemy是否打印SQL日志
DATABASE_POOL_SIZE=20                            # 数据库连接池大小
DATABASE_MAX_OVERFLOW=10                         # 数据库连接池最大溢出连接数

POSTGRES_DB=quick_fastapi_medium                 # Postgres数据库名
POSTGRES_USER=postgres                          # Postgres用户名
POSTGRES_PASSWORD=123456                        # Postgres密码
POSTGRES_HOST=localhost                         # Postgres主机
POSTGRES_PORT=5432                              # Postgres端口

APP_HOST_PORT=8001                              # 应用运行端口

REDIS_URL=redis://localhost:6379/0              # Redis连接URL
REDIS_PREFIX=quick-fastapi-medium               # Redis键前缀
REDIS_HOST_PORT=6380                            # Redis端口（如有容器映射，示例端口）

SECRET_KEY=change-me-in-production              # JWT密钥（生产环境需更改）
ALGORITHM=HS256                                 # 加密算法
ACCESS_TOKEN_EXPIRE_MINUTES=30                  # 访问Token过期分钟数
REFRESH_TOKEN_EXPIRE_DAYS=7                     # 刷新Token过期天数

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]  # 允许的CORS前端地址

LOG_LEVEL=INFO                                  # 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_FORMAT=text                                 # 日志输出格式（text/json）
LOG_FILE_ENABLED=true                           # 是否开启日志文件写入
LOG_FILE_PATH=logs/app.log                      # 日志文件路径

ENABLE_METRICS=true                             # 是否开启监控指标（Prometheus等）

SENTRY_DSN=                                     # Sentry告警DSN，留空为关闭

FIRST_SUPERUSER_EMAIL=admin@example.com         # 初始超级用户邮箱
FIRST_SUPERUSER_USERNAME=admin                  # 初始超级用户名
FIRST_SUPERUSER_PASSWORD=ChangeMe123!           # 初始超级用户密码（需及时修改！）
